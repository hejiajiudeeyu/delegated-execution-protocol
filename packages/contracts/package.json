{
  "name": "@delexec/contracts",
  "version": "0.1.1",
  "description": "Protocol enums, error registry, canonicalization helpers, and packaged templates for remote hotline execution",
  "type": "module",
  "main": "./src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./package.json": "./package.json",
    "./templates/manifest.json": "./templates/manifest.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hejiajiudeeyu/delegated-execution-protocol.git",
    "directory": "packages/contracts"
  },
  "homepage": "https://github.com/hejiajiudeeyu/delegated-execution-protocol/tree/main/packages/contracts#readme",
  "bugs": {
    "url": "https://github.com/hejiajiudeeyu/delegated-execution-protocol/issues"
  },
  "license": "Apache-2.0",
  "files": [
    "src",
    "README.md",
    "templates",
    "protocol-docs"
  ],
  "scripts": {
    "prepack": "node ../../scripts/stage-contracts-package-assets.mjs stage",
    "postpack": "node ../../scripts/stage-contracts-package-assets.mjs cleanup"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "protocol",
    "contracts",
    "hotline",
    "delegated-execution"
  ]
}
